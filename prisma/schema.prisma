generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id               String            @id @default(cuid())
  name             String
  hindsightBankId  String            @unique
  createdAt        DateTime          @default(now())
  users            User[]
  repos            Repo[]
  botInstallations BotInstallation[]
  decisions        Decision[]
}

model User {
  id          String    @id @default(cuid())
  workspaceId String
  githubId    String    @unique
  githubLogin String
  githubToken String
  avatarUrl   String    @default("")
  role        String    @default("member")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Repo {
  id             String    @id @default(cuid())
  workspaceId    String
  githubRepoId   String
  fullName       String
  installationId String    @default("")
  private        Boolean   @default(false)
  connectedAt    DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, githubRepoId])
}

model BotInstallation {
  id            String    @id @default(cuid())
  workspaceId   String
  platform      String
  platformId    String
  platformToken String    @default("")
  installedAt   DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([platform, platformId])
}

model Decision {
  id             String    @id @default(cuid())
  workspaceId    String
  hindsightId    String    @default("")
  summary        String
  rationale      String    @default("")
  alternatives   String    @default("[]")
  caveats        String    @default("")
  scope          String    @default("")
  author         String    @default("")
  source         String    @default("manual")
  sourceUrl      String    @default("")
  repoFullName   String    @default("")
  status         String    @default("standing")
  createdAt      DateTime  @default(now())
  reversedAt     DateTime?
  reversalReason String    @default("")
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}
